# Copiar para `.env.test` na raiz (ficheiro ignorado pelo Git — ver `.gitignore`).
# Nunca commitar segredos reais. Ver docs/testing/e2e-test-accounts.md para papéis A/B e fluxo.

# URL da app sob teste (Playwright + servidor Next filho)
E2E_BASE_URL=http://127.0.0.1:3000

# Utilizadores em contas distintas (projeto Supabase de teste/staging)
E2E_USER_A_EMAIL=
E2E_USER_A_PASSWORD=
E2E_USER_B_EMAIL=
E2E_USER_B_PASSWORD=

# Supabase do ambiente de teste (alinhado com NEXT_PUBLIC_* que o Next injeta no cliente)
E2E_SUPABASE_URL=
E2E_SUPABASE_ANON_KEY=
E2E_SUPABASE_SERVICE_ROLE_KEY=

# Opcional: `pnpm db:validate-rls` no mesmo projeto (Postgres session mode ou URI do Supabase)
DATABASE_URL=

# Opcional: senha explícita só para o script de validação RLS (se A e B partilham a mesma senha de teste)
# VALIDATION_TEST_PASSWORD=

# --- GitHub Actions (`.github/workflows/e2e-security.yml`) ---
# Secrets esperados: E2E_DATABASE_URL, E2E_SUPABASE_URL, E2E_SUPABASE_ANON_KEY,
# E2E_SUPABASE_SERVICE_ROLE_KEY, E2E_USER_A_EMAIL, E2E_USER_A_PASSWORD, E2E_USER_B_EMAIL.
# `VALIDATION_TEST_PASSWORD` no CI usa o mesmo valor que `E2E_USER_A_PASSWORD` (senha partilhada A/B no script).

# --- Hardening (headers já em next.config; variáveis opcionais) ---
# Origens extra para Server Actions atrás de proxy (CSRF). Separadas por vírgula.
# SERVER_ACTIONS_ALLOWED_ORIGINS=
# Máximo de POSTs Server Action / IP / minuto (middleware). Por defeito 180.
# SECURITY_SERVER_ACTION_MAX_PER_MINUTE=
