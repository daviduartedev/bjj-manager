# =====================================================
# BJJ Manager - Environment Variables
# =====================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# Nunca commit .env.local no Git.

# -----------------------------------------------------
# Supabase - Public (cliente browser)
# -----------------------------------------------------
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------
# Supabase - Server-side (NUNCA expor no cliente)
# -----------------------------------------------------
# Service role bypassa RLS - usar apenas em rotas server-side criticas (ex: webhooks)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------
# App
# -----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="BJJ Manager"

# -----------------------------------------------------
# Locale
# -----------------------------------------------------
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Sao_Paulo
