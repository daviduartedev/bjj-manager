# =====================================================
# Casca , Gestão de Academias de BJJ · variáveis de ambiente
# =====================================================
# Copie este arquivo para .env.local e preencha os valores reais.
# Nunca commit .env.local no Git.

# -----------------------------------------------------
# Supabase - Public (cliente browser)
# -----------------------------------------------------
# Obtenha em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------
# Supabase - Server-side (NUNCA expor no cliente)
# -----------------------------------------------------
# Service role bypassa RLS - usar apenas em rotas server-side criticas (ex: webhooks)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Connection string Postgres , usado por `pnpm db:apply`. Password = Database password no dashboard, não as API keys.
# Direct (exemplo): postgresql://postgres:SUA_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Opcional: senha de teste para pnpm db:validate-rls (emails maikon@aslam.com.br e rls-validation-b@aslam.com.br)
# VALIDATION_TEST_PASSWORD=

# -----------------------------------------------------
# App
# -----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Casca"

# -----------------------------------------------------
# PDF / documentos (**REC-3**) — servidor Node (server actions / lib/documents/renderer)
# -----------------------------------------------------
# Se omitido: host local/dev → playwright; VERCEL=1 → chama só a Lambda da rota interna (+ puppeteer + @sparticuz/chromium).
# PDF_RENDERER_DRIVER=playwright-local
# PDF_RENDERER_DRIVER=puppeteer-serverless

# Produção na Vercel — obrigatório (Bearer na rota /api/internal/pdf-from-html ; mín. 24 caracteres).
# Gerar algo aleatório: openssl rand -base64 32
# PDF_INTERNAL_RENDER_TOKEN=

# Se o projecto tiver Deployment Protection (Vercel Authentication / password), activar no dashboard
# “Protection Bypass for Automation”. A Vercel injeita **VERCEL_AUTOMATION_BYPASS_SECRET** nas Lambdas.
# Se esse valor não aparecer nas variáveis (ambiente antigo ou bug), cópia o mesmo valor do dashboard aqui:
# PDF_DEPLOYMENT_PROTECTION_BYPASS=
# O renderizador envia bypass no header **e** na query do self-fetch (URL = **VERCEL_URL**).

# Opcional: **PDF_RENDER_ORIGIN** — apenas se precisares de forçar outro host (URL sem `/` final).
# Por defeito usa **VERCEL_URL** para evitar **DEPLOYMENT_NOT_FOUND**.
# PDF_RENDER_ORIGIN=https://example.com
# -----------------------------------------------------
# Locale
# -----------------------------------------------------
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_DEFAULT_TIMEZONE=America/Sao_Paulo
